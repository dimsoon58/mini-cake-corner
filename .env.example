# Copy this file to `.env` and fill in the values from your Supabase project.
# Find them in the Supabase dashboard under Project Settings → API,
# or in the Lovable project's connected Supabase integration.
# These are VITE_ (client-side) values and are safe to expose in the browser.

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
